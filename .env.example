# E2E Test Configuration
# Copy this file to .env and fill in your values.

# App profile — single env var replaces IS_LITE, IS_FORGE, ZENUML_DOMAIN, ZENUML_SPACE
# Valid profiles: zenuml-lite@stg, zenuml-full@stg, diagramly@stg,
#                 zenuml-lite@prod, zenuml-full@prod, diagramly@prod
APP=zenuml-lite@stg

# Confluence robot account credentials
ZENUML_STAGE_USERNAME=robot1yanhui@aol.com
ZENUML_STAGE_PASSWORD=
ATLASSIAN_OTP=

# Optional overrides (only needed if APP is not set)
# ZENUML_DOMAIN=zenuml-stg.atlassian.net
# ZENUML_SPACE=ZS
# IS_LITE=true
# IS_FORGE=true
# PARENT_PAGE_ID=
# PAGE_ID=
